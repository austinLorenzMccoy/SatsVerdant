# Kaggle API Credentials (get from https://www.kaggle.com/settings)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# MLflow Tracking
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=waste-classification

# Model Configuration
MODEL_ARCHITECTURE=MobileNetV3-Large
INPUT_SIZE=224
BATCH_SIZE=32
EPOCHS=20
LEARNING_RATE=0.001

# Data Paths
RAW_DATA_DIR=./data/raw
UNIFIED_DATA_DIR=./data/unified
SYNTHETIC_DATA_DIR=./data/synthetic
MODEL_OUTPUT_DIR=./models
